# Local gate before pushing — typecheck, lint, unit, then a runtime smoke test
# that loads every docs page (components + examples) headless and fails on any
# console error / pageerror / dev warning. Keeps GitHub CI lean (no extra
# browser sweep there); this is the local backstop. Skip everything with
# `git push --no-verify`, or just the smoke with `SKIP_SMOKE=1 git push`.
npm run typecheck && npm run lint && npm run test:unit && npm run test:smoke
