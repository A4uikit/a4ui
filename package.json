{
  "name": "@a4ui/core",
  "version": "0.15.0",
  "description": "A4ui — Spatial Glass design system & component library for SolidJS (Kobalte behavior + Tailwind glass tokens + motion).",
  "type": "module",
  "license": "MIT",
  "author": "Luis Alfredo Rivera Acuña <1alfredorivera@gmail.com>",
  "homepage": "https://a4ui.pages.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A4uikit/a4ui.git"
  },
  "bugs": {
    "url": "https://github.com/A4uikit/a4ui/issues"
  },
  "keywords": [
    "solid-js",
    "solidjs",
    "components",
    "component-library",
    "design-system",
    "ui-kit",
    "tailwindcss",
    "kobalte",
    "glassmorphism"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "preset.js",
    "src/index.ts",
    "src/ui",
    "src/lib",
    "src/layout",
    "src/themes",
    "src/commerce",
    "src/charts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./commerce": {
      "types": "./dist/commerce/index.d.ts",
      "solid": "./src/commerce/index.ts",
      "import": "./dist/commerce.js",
      "default": "./dist/commerce.js"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "solid": "./src/charts/index.ts",
      "import": "./dist/charts.js",
      "default": "./dist/charts.js"
    },
    "./preset": {
      "import": "./preset.js",
      "default": "./preset.js"
    },
    "./styles.css": "./dist/styles.css",
    "./full.css": "./dist/full.css",
    "./elements": {
      "import": "./dist/elements.js",
      "default": "./dist/elements.js"
    },
    "./elements.css": "./dist/elements.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.3",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/sync-version.mjs",
    "build": "vite build && npm run build:elements",
    "build:elements": "vite build --config vite.elements.config.ts && node scripts/build-elements-css.mjs",
    "dev": "vite build --watch",
    "preview": "node scripts/gen-llms.mjs && vite --config vite.preview.config.ts",
    "preview:build": "node scripts/gen-llms.mjs && vite build --config vite.preview.config.ts",
    "gen:llms": "node scripts/gen-llms.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:a11y": "playwright test a11y --project=desktop",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:report": "playwright show-report",
    "test:package": "node scripts/test-package.mjs",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run build && npm run test:package",
    "prepublishOnly": "npm run validate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md,yml,html}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.12",
    "@tanstack/solid-virtual": "^3.13.33",
    "clsx": "^2.1.1",
    "lucide-solid": "^1.23.0",
    "motion": "^12.42.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "marked": "^18.0.6",
    "playwright-core": "^1.61.1",
    "prettier": "^3.9.5",
    "solid-element": "^1.9.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  }
}
