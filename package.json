{
  "name": "@a4ui/core",
  "version": "0.2.0",
  "description": "A4ui — Spatial Glass design system & component library for SolidJS (Kobalte behavior + Tailwind glass tokens + motion).",
  "type": "module",
  "license": "MIT",
  "author": "Luis Alfredo Rivera Acuña <1alfredorivera@gmail.com>",
  "homepage": "https://a4uikit.github.io/a4ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A4uikit/a4ui.git"
  },
  "bugs": {
    "url": "https://github.com/A4uikit/a4ui/issues"
  },
  "keywords": [
    "solid-js",
    "solidjs",
    "components",
    "component-library",
    "design-system",
    "ui-kit",
    "tailwindcss",
    "kobalte",
    "glassmorphism"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "preset.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./preset": "./preset.js",
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "preview": "node scripts/gen-llms.mjs && vite --config vite.preview.config.ts",
    "preview:build": "node scripts/gen-llms.mjs && vite build --config vite.preview.config.ts",
    "gen:llms": "node scripts/gen-llms.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.13"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.12",
    "@tanstack/solid-virtual": "^3.13.33",
    "clsx": "^2.1.1",
    "lucide-solid": "^1.23.0",
    "solid-motionone": "^1.0.4",
    "solid-transition-group": "^0.3.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint-plugin-solid": "^0.14.5",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vite-plugin-solid": "^2.11.12"
  }
}
